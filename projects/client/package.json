  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.86.0",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.9",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.8.3",
    "uniwind": "^1.2.7"
  },
  "version": "2.0.1"
